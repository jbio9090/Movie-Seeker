{
    "name": "jb/movieseeker",
    "autoload": {
        "psr-4": {
            "App\\": "src/App/"
        }
    },
    "require": {
        "guzzlehttp/guzzle": "^7.9",
        "vlucas/phpdotenv": "^5.6",
        "phpmailer/phpmailer": "^6.10",
        "google/apiclient": "*",
        "railsware/mailtrap-php": "^3.12",
        "php-http/guzzle7-adapter": "^1.1"
    },
    "config": {
        "process-timeout": 0,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
